@dataclass
class AppState:
    original_path: Path
    temp_path: Path
    calendar: Calendar
    dirty: bool = False
    saved_session_bytes: bytes = b""
    component_ids: dict[int, str] = field(default_factory=dict)
    cid_to_component: dict[str, Event] = field(default_factory=dict)
    shutdown_requested: bool = False
    shutdown_message: str = ""

    def register_component(self, component: Event) -> str:
        key = id(component)
        cid = self.component_ids.get(key)
        if cid is None:
            cid = f"c-{uuid.uuid4()}"
            self.component_ids[key] = cid
            self.cid_to_component[cid] = component
        return cid

    def rebuild_component_index(self) -> None:
        current: dict[str, Event] = {}
        for component in iter_events(self.calendar):
            cid = self.register_component(component)
            current[cid] = component
        self.cid_to_component = current

    def get_component(self, cid: str) -> Event | None:
        component = self.cid_to_component.get(cid)
        if component is None:
            return None
        if not any(existing is component for existing in iter_events(self.calendar)):
            return None
        return component


class AppError(Exception):
    pass


def main() -> int:
    try:
        original_path, requested_port = parse_cli(sys.argv)
        calendar, dirty = load_calendar(original_path)
        temp_path = create_temp_session_file(calendar)
        state = AppState(
            original_path=original_path,
            temp_path=temp_path,
            calendar=calendar,
            dirty=dirty,
        )
        ensure_event_metadata(state)
        state.saved_session_bytes = state.calendar.to_ical()
        state.dirty = False
        write_temp(state)
        server = bind_server(state, requested_port)
        try:
            url = f"http://127.0.0.1:{server.server_port}/"
            sys.stdout.write(f"Listening on {url}\n")
            sys.stdout.flush()
            server.serve_forever()
        finally:
            server.server_close()
            cleanup_temp_file(state)
        return 0
    except KeyboardInterrupt:
        return 0
    except AppError as exc:
        print(f"{APP_NAME}: {exc}", file=sys.stderr)
        return 1
    except Exception as exc:  # pragma: no cover - last resort
        print(f"{APP_NAME}: unexpected error: {exc}", file=sys.stderr)
        traceback.print_exc(file=sys.stderr)
        return 1


def parse_cli(argv: list[str]) -> tuple[Path, int | None]:
    if len(argv) not in {2, 3}:
        raise AppError("usage: icswebedit /path/to/calendar.ics [port]")

    original_path = Path(argv[1]).expanduser()
    if original_path.exists() and not original_path.is_file():
        raise AppError(f"not a file: {original_path}")

    parent = original_path.parent
    if not parent.exists():
        raise AppError(f"parent directory does not exist: {parent}")

    requested_port: int | None = None
    if len(argv) == 3:
        try:
            requested_port = int(argv[2])
        except ValueError as exc:
            raise AppError(f"invalid port: {argv[2]}") from exc
        if not (1 <= requested_port <= 65535):
            raise AppError(f"invalid port: {requested_port}")

    return original_path, requested_port


def create_empty_calendar() -> Calendar:
    calendar = Calendar()
    calendar.add("version", "2.0")
    calendar.add("prodid", "-//icswebedit//EN")
    calendar.add("calscale", "GREGORIAN")
    return calendar


def load_calendar(path: Path) -> tuple[Calendar, bool]:
    if path.exists():
        raw = path.read_bytes()
        try:
            calendar = Calendar.from_ical(raw)
        except Exception as exc:
            raise AppError(f"failed to parse ICS file: {path}") from exc
    else:
        calendar = create_empty_calendar()

    if calendar.get("version") is None:
        calendar["VERSION"] = "2.0"
    if calendar.get("prodid") is None:
        calendar["PRODID"] = "-//icswebedit//EN"
    if calendar.get("calscale") is None:
        calendar["CALSCALE"] = "GREGORIAN"

    dirty = False
    for component in iter_events(calendar):
        if component.get("UID") is None:
            component["UID"] = generate_uid()
            dirty = True
        if component.get("DTSTAMP") is None:
            set_component_value(component, "DTSTAMP", now_utc())
            dirty = True
        if component.get("CREATED") is None:
            set_component_value(component, "CREATED", now_utc())
            dirty = True
        if component.get("LAST-MODIFIED") is None:
            set_component_value(component, "LAST-MODIFIED", now_utc())
            dirty = True

    return calendar, dirty


def create_temp_session_file(calendar: Calendar) -> Path:
    with tempfile.NamedTemporaryFile(
        prefix=f"{APP_NAME}-",
        suffix=".ics",
        delete=False,
    ) as handle:
        handle.write(calendar.to_ical())
        handle.flush()
        os.fsync(handle.fileno())
        return Path(handle.name)


def ensure_event_metadata(state: AppState) -> None:
    changed = False
    for component in iter_events(state.calendar):
        cid = state.register_component(component)
        state.cid_to_component[cid] = component
        if component.get("UID") is None:
            component["UID"] = generate_uid()
            changed = True
        if component.get("DTSTAMP") is None:
            set_component_value(component, "DTSTAMP", now_utc())
            changed = True
        if component.get("CREATED") is None:
            set_component_value(component, "CREATED", now_utc())
            changed = True
        if component.get("LAST-MODIFIED") is None:
            set_component_value(component, "LAST-MODIFIED", now_utc())
            changed = True
    if changed:
        state.dirty = True


def write_temp(state: AppState) -> None:
    data = state.calendar.to_ical()
    state.temp_path.write_bytes(data)


def refresh_dirty(state: AppState) -> None:
    state.dirty = state.calendar.to_ical() != state.saved_session_bytes


def prune_past_non_recurring_events(state: AppState) -> None:
    now_local = datetime.now().astimezone()
    kept: list[Any] = []
    changed = False
    for component in state.calendar.subcomponents:
        if getattr(component, "name", "") != "VEVENT":
            kept.append(component)
            continue
        if is_recurring_component(component):
            kept.append(component)
            continue
        if component_can_edit_or_delete(component, now_local):
            kept.append(component)
            continue
        changed = True
    if changed:
        state.calendar.subcomponents = kept
        state.component_ids.clear()
        state.cid_to_component.clear()
        state.rebuild_component_index()


def save_original(state: AppState) -> None:
    try:
        prune_past_non_recurring_events(state)
        state.original_path.parent.mkdir(parents=True, exist_ok=True)

        if state.original_path.exists():
            make_backup(state.original_path)

        fd, staging_name = tempfile.mkstemp(
            prefix=f".{state.original_path.stem}-",
            suffix=state.original_path.suffix or ".ics",
            dir=str(state.original_path.parent),
        )
        staging_path = Path(staging_name)
        try:
            with os.fdopen(fd, "wb") as handle:
                handle.write(state.calendar.to_ical())
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(staging_path, state.original_path)
            fsync_directory_if_supported(state.original_path.parent)
            state.saved_session_bytes = state.calendar.to_ical()
            state.dirty = False
        except Exception:
            try:
                if staging_path.exists():
                    staging_path.unlink()
            except OSError:
                pass
            raise
    except AppError:
        raise
    except Exception as exc:
        raise AppError(f"failed to save calendar: {exc}") from exc


def make_backup(path: Path) -> Path:
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    suffix = path.suffix or ".ics"
    backup_name = f".{path.stem}_{timestamp}{suffix}"
    backup_path = path.with_name(backup_name)
    try:
        shutil.copy2(path, backup_path)
    except Exception as exc:
        raise AppError(f"failed to create backup: {backup_path}") from exc
    return backup_path


def fsync_directory_if_supported(path: Path) -> None:
    if os.name == "nt":
        return
    flags = getattr(os, "O_RDONLY", 0)
    descriptor = os.open(path, flags)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def cleanup_temp_file(state: AppState) -> None:
    try:
        state.temp_path.unlink(missing_ok=True)
    except OSError:
        pass


def iter_events(calendar: Calendar):
    for component in calendar.subcomponents:
        if getattr(component, "name", "") == "VEVENT":
            yield component


def now_utc() -> datetime:
    return datetime.now(UTC).replace(microsecond=0)


def generate_uid() -> str:
    return f"{uuid.uuid4()}@{APP_NAME}"


def format_utc_iso(value: datetime) -> str:
    return value.astimezone(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_utc_iso(value: str) -> datetime:
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError as exc:
        raise AppError("invalid UTC datetime value") from exc
    if parsed.tzinfo is None:
        raise AppError("datetime must be timezone-aware UTC")
    return parsed.astimezone(UTC).replace(microsecond=0)


def decoded_value(component: Event, key: str) -> Any:
    try:
        return component.decoded(key)
    except Exception:
        return None


def is_all_day_component(component: Event) -> bool:
    start = decoded_value(component, "DTSTART")
    return isinstance(start, date) and not isinstance(start, datetime)


def coerce_datetime_to_utc(value: Any) -> datetime:
    if not isinstance(value, datetime):
        raise AppError("expected datetime value")
    if value.tzinfo is None:
        local_tz = datetime.now().astimezone().tzinfo
        if local_tz is None:
            raise AppError("unable to determine local timezone")
        value = value.replace(tzinfo=local_tz)
    return value.astimezone(UTC).replace(microsecond=0)


def event_start(component: Event) -> date | datetime:
    start = decoded_value(component, "DTSTART")
    if start is None:
        raise AppError("event is missing DTSTART")
    return start


def event_end(component: Event) -> date | datetime:
    start = event_start(component)
    end = decoded_value(component, "DTEND")
    duration = decoded_value(component, "DURATION")

    if end is not None:
        return end
    if duration is not None:
        return start + duration
    if isinstance(start, datetime):
        return start
    return start + timedelta(days=1)


def event_start_utc(component: Event) -> datetime:
    start = event_start(component)
    if isinstance(start, datetime):
        return coerce_datetime_to_utc(start)
    return datetime.combine(start, time.min, tzinfo=UTC)


def event_end_utc(component: Event) -> datetime:
    end = event_end(component)
    if isinstance(end, datetime):
        return coerce_datetime_to_utc(end)
    return datetime.combine(end, time.min, tzinfo=UTC)


def all_day_inclusive_end_date(start: date, exclusive_end: date) -> date:
    if exclusive_end <= start:
        return start
    return exclusive_end - timedelta(days=1)


def is_recurring_component(component: Event) -> bool:
    return component.get("RRULE") is not None


def recurrence_text(component: Event) -> str:
    rrule = component.get("RRULE")
    if rrule is None:
        return ""
    text = rrule.to_ical().decode("utf-8") if hasattr(rrule, "to_ical") else str(rrule)
    return text.replace("RRULE:", "")


def recurrence_freq_value(component: Event) -> str:
    text = recurrence_text(component).strip()
    if not text:
        return ""
    for part in text.split(";"):
        if part.startswith("FREQ="):
            value = part.removeprefix("FREQ=").strip().upper()
            if value in {"DAILY", "WEEKLY", "MONTHLY"}:
                return value
    return ""


def alarm_choice_value(component: Event) -> str:
    for subcomponent in getattr(component, "subcomponents", []):
        if getattr(subcomponent, "name", "") != "VALARM":
            continue
        trigger = decoded_value(subcomponent, "TRIGGER")
        if isinstance(trigger, timedelta):
            positive = -trigger if trigger.total_seconds() < 0 else trigger
            for key, delta in ALARM_TRIGGER_MAP.items():
                if delta == positive:
                    return key
    return ""


def component_can_edit_or_delete(component: Event, now_local: datetime) -> bool:
    if is_recurring_component(component):
        return True

    if is_all_day_component(component):
        start = event_start(component)
        return isinstance(start, date) and not isinstance(start, datetime) and start >= now_local.date()

    return event_end_utc(component) >= now_local.astimezone(UTC)


def list_events(state: AppState) -> list[dict[str, Any]]:
    now_local = datetime.now().astimezone()
    now_utc = now_local.astimezone(UTC)
    recurring_window_end = now_utc + timedelta(days=365 * RECURRING_LOOKAHEAD_YEARS)
    recurring_window_start = now_utc - timedelta(days=2)
    items: list[dict[str, Any]] = []

    for component in iter_events(state.calendar):
        cid = state.register_component(component)
        uid = str(component.get("UID", ""))
        recurring = is_recurring_component(component)
        editable = component_can_edit_or_delete(component, now_local)
        base = {
            "id": cid,
            "source_id": cid,
            "uid": uid,
            "summary": str(component.get("SUMMARY", "")),
            "location": str(component.get("LOCATION", "")),
            "description": str(component.get("DESCRIPTION", "")),
            "all_day": is_all_day_component(component),
            "recurring": recurring,
            "editable": editable,
            "deletable": editable,
            "rrule": recurrence_text(component),
        }
        if recurring:
            item = list_next_recurring_occurrence(component, base, recurring_window_start, recurring_window_end, now_local)
            if item is not None:
                items.append(item)
        else:
            event_item = build_nonrecurring_item(component, base, now_local)
            if event_item is not None:
                items.append(event_item)

    items.sort(key=event_sort_key)
    return items


def build_nonrecurring_item(
    component: Event,
    base: dict[str, Any],
    now_local: datetime,
) -> dict[str, Any] | None:
    if base["all_day"]:
        start = event_start(component)
        end = event_end(component)
        assert isinstance(start, date) and not isinstance(start, datetime)
        assert isinstance(end, date) and not isinstance(end, datetime)
        if start < now_local.date():
            return None
        item = dict(base)
        item["start_date"] = start.isoformat()
        item["end_date"] = all_day_inclusive_end_date(start, end).isoformat()
        item["sort_key"] = f"{start.isoformat()}T00:00:00Z"
        item["start_utc"] = None
        item["end_utc"] = None
        return item

    start_utc = event_start_utc(component)
    end_utc = event_end_utc(component)
    if end_utc < now_local.astimezone(UTC):
        return None
    item = dict(base)
    item["start_utc"] = format_utc_iso(start_utc)
    item["end_utc"] = format_utc_iso(end_utc)
    item["sort_key"] = item["start_utc"]
    return item


def list_next_recurring_occurrence(
    component: Event,
    base: dict[str, Any],
    window_start: datetime,
    window_end: datetime,
    now_local: datetime,
) -> dict[str, Any] | None:
    calendar = create_empty_calendar()
    for other in stateful_vtimezone_components(component):
        calendar.add_component(copy.deepcopy(other))
    calendar.add_component(copy.deepcopy(component))

    occurrences = recurring_ical_events.of(calendar).between(window_start, window_end)
    for occurrence in occurrences:
        item = build_occurrence_item(component, occurrence, base, now_local)
        if item is not None:
            return item
    return None


def stateful_vtimezone_components(component: Event) -> list[Any]:
    parent = getattr(component, "parent", None)
    if parent is None:
        return []
    return [item for item in getattr(parent, "subcomponents", []) if getattr(item, "name", "") == "VTIMEZONE"]


def build_occurrence_item(
    component: Event,
    occurrence: Event,
    base: dict[str, Any],
    now_local: datetime,
) -> dict[str, Any] | None:
    all_day = base["all_day"]
    if all_day:
        start = event_start(occurrence)
        end = event_end(occurrence)
        assert isinstance(start, date) and not isinstance(start, datetime)
        assert isinstance(end, date) and not isinstance(end, datetime)
        if start < now_local.date():
            return None
        item = dict(base)
        item["occurrence_start_date"] = start.isoformat()
        item["occurrence_end_date"] = all_day_inclusive_end_date(start, end).isoformat()
        item["start_date"] = event_start(component).isoformat()
        item["end_date"] = all_day_inclusive_end_date(event_start(component), event_end(component)).isoformat()
        item["start_utc"] = None
        item["end_utc"] = None
        item["occurrence_start_utc"] = None
        item["occurrence_end_utc"] = None
        item["sort_key"] = f"{start.isoformat()}T00:00:00Z"
        return item

    start_utc = event_start_utc(occurrence)
    end_utc = event_end_utc(occurrence)
    if end_utc < now_local.astimezone(UTC):
        return None
    item = dict(base)
    item["start_utc"] = format_utc_iso(event_start_utc(component))
    item["end_utc"] = format_utc_iso(event_end_utc(component))
    item["occurrence_start_utc"] = format_utc_iso(start_utc)
    item["occurrence_end_utc"] = format_utc_iso(end_utc)
    item["sort_key"] = item["occurrence_start_utc"]
    return item


def event_sort_key(item: dict[str, Any]) -> str:
    return str(item.get("sort_key") or item.get("occurrence_start_utc") or item.get("start_date") or "")


def parse_form(handler: BaseHTTPRequestHandler) -> dict[str, str]:
    length = int(handler.headers.get("Content-Length", "0"))
    raw = handler.rfile.read(length).decode("utf-8") if length else ""
    parsed = parse_qs(raw, keep_blank_values=True)
    return {key: values[-1] for key, values in parsed.items()}


def add_event(state: AppState, form: dict[str, str]) -> None:
    component = Event()
    cid = state.register_component(component)
    apply_form_to_component(component, form)
    stamp = now_utc()
    component["UID"] = generate_uid()
    set_component_value(component, "DTSTAMP", stamp)
    set_component_value(component, "CREATED", stamp)
    set_component_value(component, "LAST-MODIFIED", stamp)
    state.calendar.add_component(component)
    state.cid_to_component[cid] = component
    refresh_dirty(state)
    write_temp(state)


def edit_event(state: AppState, event_id: str, form: dict[str, str]) -> None:
    component = require_component(state, event_id)
    if not component_can_edit_or_delete(component, datetime.now().astimezone()):
        raise AppError("event is not editable")
    apply_form_to_component(component, form, existing=component)
    stamp = now_utc()
    set_component_value(component, "DTSTAMP", stamp)
    set_component_value(component, "LAST-MODIFIED", stamp)
    if component.get("CREATED") is None:
        set_component_value(component, "CREATED", stamp)
    if component.get("UID") is None:
        component["UID"] = generate_uid()
    refresh_dirty(state)
    write_temp(state)


def delete_event(state: AppState, event_id: str) -> None:
    component = require_component(state, event_id)
    if not component_can_edit_or_delete(component, datetime.now().astimezone()):
        raise AppError("event is not deletable")
    state.calendar.subcomponents.remove(component)
    state.cid_to_component.pop(event_id, None)
    state.component_ids.pop(id(component), None)
    refresh_dirty(state)
    write_temp(state)


def require_component(state: AppState, event_id: str) -> Event:
    component = state.get_component(event_id)
    if component is None:
        raise AppError("event not found")
    return component


def apply_form_to_component(component: Event, form: dict[str, str], existing: Event | None = None) -> None:
    summary = form.get("summary", "").strip()
    if not summary:
        raise AppError("summary is required")

    all_day = form.get("all_day") == "on"
    if all_day:
        start_date = parse_date_field(form.get("start_date", ""), "start date")
        if form.get("end_date", "").strip():
            end_date_inclusive = parse_date_field(form["end_date"], "end date")
        else:
            end_date_inclusive = start_date

        validate_start_future(start_date, existing)
        if end_date_inclusive < start_date:
            raise AppError("start must be same or before end")
        set_component_text(component, "SUMMARY", summary)
        set_component_text(component, "LOCATION", form.get("location", ""))
        set_component_text(component, "DESCRIPTION", form.get("description", ""))
        set_component_value(component, "DTSTART", start_date)
        set_component_value(component, "DTEND", end_date_inclusive + timedelta(days=1))
    else:
        start_utc = parse_utc_iso(form.get("start_utc", ""))
        end_utc = parse_utc_iso(form.get("end_utc", ""))

        validate_start_future(start_utc, existing)
        if end_utc <= start_utc:
            raise AppError("start must be before end")
        set_component_text(component, "SUMMARY", summary)
        set_component_text(component, "LOCATION", form.get("location", ""))
        set_component_text(component, "DESCRIPTION", form.get("description", ""))
        set_component_value(component, "DTSTART", start_utc)
        set_component_value(component, "DTEND", end_utc)

    component.pop("DURATION", None)
    set_component_text(component, "TRANSP", "OPAQUE")
    update_rrule(component, form.get("rrule", ""))
    update_alarm(component, form.get("alarm_trigger", ""))


def validate_start_future(value: date | datetime, existing: Event | None) -> None:
    if isinstance(value, datetime):
        if value < now_utc():
            if existing is None:
                raise AppError("start must be in the future")
            current_start = event_start(existing)
            if isinstance(current_start, datetime) and coerce_datetime_to_utc(current_start) < now_utc():
                return
            raise AppError("start must be in the future")
        return

    if value < datetime.now().astimezone().date():
        if existing is None:
            raise AppError("start must be in the future")
        current_start = event_start(existing)
        if isinstance(current_start, date) and not isinstance(current_start, datetime) and current_start < datetime.now().astimezone().date():
            return
        raise AppError("start must be in the future")


def parse_date_field(value: str, label: str) -> date:
    if not value.strip():
        raise AppError(f"{label} is required")
    try:
        return date.fromisoformat(value)
    except ValueError as exc:
        raise AppError(f"invalid {label}") from exc


def set_component_text(component: Event, key: str, value: str) -> None:
    cleaned = value.strip()
    if cleaned:
        component[key] = cleaned
    else:
        component.pop(key, None)


def set_component_value(component: Event, key: str, value: Any) -> None:
    component.pop(key, None)
    component.add(key, value)


def update_rrule(component: Event, value: str) -> None:
    cleaned = value.strip()
    freq = cleaned.upper()
    if freq not in {"", "DAILY", "WEEKLY", "MONTHLY"}:
        freq = ""
    if not freq:
        component.pop("RRULE", None)
        return
    try:
        candidate = Calendar.from_ical(
            (
                "BEGIN:VCALENDAR\r\n"
                "BEGIN:VEVENT\r\n"
                f"DTSTART:{now_utc().strftime('%Y%m%dT%H%M%SZ')}\r\n"
                f"RRULE:FREQ={freq}\r\n"
                "END:VEVENT\r\n"
                "END:VCALENDAR\r\n"
            ).encode("utf-8")
        )
        event = next(iter_events(candidate))
        parsed = event.get("RRULE")
        if parsed is None:
            raise AppError("invalid RRULE")
        component["RRULE"] = parsed
    except AppError:
        raise
    except Exception as exc:
        raise AppError("invalid RRULE") from exc


def update_alarm(component: Event, value: str) -> None:
    allowed = ALARM_TRIGGER_MAP.get(value.strip(), None)
    component.subcomponents = [
        subcomponent
        for subcomponent in getattr(component, "subcomponents", [])
        if getattr(subcomponent, "name", "") != "VALARM"
    ]
    if allowed is None:
        return
    alarm = Alarm()
    alarm.add("action", "DISPLAY")
    alarm.add("trigger", -allowed)
    component.add_component(alarm)


def bind_server(state: AppState, requested_port: int | None) -> ThreadingHTTPServer:
    if requested_port is not None:
        try:
            server = AppServer(("127.0.0.1", requested_port), Handler, state)
        except OSError as exc:
            raise AppError(f"port {requested_port} is unavailable") from exc
        return server

    last_error: OSError | None = None
    for port in range(DEFAULT_PORT, MAX_AUTO_PORT + 1):
        try:
            return AppServer(("127.0.0.1", port), Handler, state)
        except OSError as exc:
            last_error = exc
    raise AppError(f"no free port available in range {DEFAULT_PORT}-{MAX_AUTO_PORT}") from last_error


class AppServer(ThreadingHTTPServer):
    daemon_threads = True
    allow_reuse_address = True

    def __init__(self, server_address: tuple[str, int], handler_class: type[BaseHTTPRequestHandler], state: AppState):
        super().__init__(server_address, handler_class)
        self.state = state


class Handler(BaseHTTPRequestHandler):
    server: AppServer

    def current_language(self) -> str:
        return preferred_language(self.headers.get("Accept-Language"))

    def log_message(self, format: str, *args: Any) -> None:
        return

    def do_GET(self) -> None:
        try:
            parsed = urlparse(self.path)
            if parsed.path == "/":
                self.render_home()
            elif parsed.path == "/new":
                self.render_form_page("new")
            elif parsed.path == "/edit":
                params = parse_qs(parsed.query)
                event_id = params.get("id", [""])[-1]
                self.render_form_page("edit", event_id)
            elif parsed.path == "/api/events":
                self.render_events_json()
            elif parsed.path == "/health":
                self.send_text(HTTPStatus.OK, "ok\n")
            else:
                self.send_error_page(HTTPStatus.NOT_FOUND, "Not found")
        except AppError as exc:
            self.send_error_page(HTTPStatus.BAD_REQUEST, str(exc))
        except Exception as exc:
            self.send_error_page(HTTPStatus.INTERNAL_SERVER_ERROR, str(exc))

    def do_POST(self) -> None:
        try:
            parsed = urlparse(self.path)
            if parsed.path == "/new":
                add_event(self.server.state, parse_form(self))
                self.redirect("/")
                return
            if parsed.path == "/edit":
                params = parse_qs(parsed.query)
                event_id = params.get("id", [""])[-1]
                edit_event(self.server.state, event_id, parse_form(self))
                self.redirect("/")
                return
            if parsed.path == "/delete":
                form = parse_form(self)
                if form.get("confirm") != "yes":
                    raise AppError("delete confirmation required")
                delete_event(self.server.state, form.get("id", ""))
                self.redirect("/")
                return
            if parsed.path == "/save":
                save_original(self.server.state)
                write_temp(self.server.state)
                self.redirect("/")
                return
            if parsed.path == "/exit":
                cleanup_temp_file(self.server.state)
                self.render_shutdown_page(tr(self.current_language(), "server_stopped"))
                self.trigger_shutdown("exit")
                return
            self.send_error_page(HTTPStatus.NOT_FOUND, "Not found")
        except AppError as exc:
            self.send_error_page(HTTPStatus.BAD_REQUEST, str(exc))
        except Exception as exc:
            self.send_error_page(HTTPStatus.INTERNAL_SERVER_ERROR, str(exc))

