        self.send_html(status, body)


def escape_html(value: str) -> str:
    return html.escape(value, quote=False)


def escape_attr(value: str) -> str:
    return html.escape(value, quote=True)


def render_select_options(options: list[tuple[str, str]], selected: str, lang: str) -> str:
    rendered: list[str] = []
    for value, label in options:
        is_selected = " selected" if value == selected else ""
        rendered.append(
            f'<option value="{escape_attr(value)}"{is_selected}>{escape_html(localize_option_label(lang, label))}</option>'
        )
    return "".join(rendered)


