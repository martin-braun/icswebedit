def home_script(lang: str) -> str:
    translations = js_translations(lang)
    script = """
<script>
const I18N = __I18N__;
const clockFormatter = new Intl.DateTimeFormat(undefined, {
  dateStyle: 'full',
  timeStyle: 'medium'
});

function updateLiveClock() {
  const clock = document.getElementById('live-clock');
  if (!clock) return;
  clock.textContent = `🕒 ${clockFormatter.format(new Date())}`;
}

async function loadEvents() {
  const container = document.getElementById('events');
  try {
    const response = await fetch('/api/events');
    const events = await response.json();
    if (!events.length) {
      container.textContent = I18N.no_future_events;
      return;
    }
    const groups = new Map();
    for (const event of events) {
      const key = event.all_day
        ? (event.occurrence_start_date || event.start_date)
        : localDateKey(event.occurrence_start_utc || event.start_utc);
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key).push(event);
    }
    container.innerHTML = '';
    for (const [key, entries] of groups.entries()) {
      const section = document.createElement('section');
      section.className = 'day-group';
      const title = document.createElement('h3');
      title.textContent = formatDateLabel(key);
      section.appendChild(title);
      for (const event of entries) {
        section.appendChild(renderEvent(event));
      }
      container.appendChild(section);
    }
  } catch (error) {
    container.textContent = I18N.failed_load_events;
  }
}

function localDateKey(utcIso) {
  const date = new Date(utcIso);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function formatDateLabel(isoDate) {
  const date = new Date(`${isoDate}T12:00:00`);
  return date.toLocaleDateString(undefined, { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
}

function formatTimeRange(event) {
  if (event.all_day) return `${I18N.all_day} ${event.summary || '(untitled)'}`;
  const start = new Date(event.occurrence_start_utc || event.start_utc);
  const end = new Date(event.occurrence_end_utc || event.end_utc);
  const format = { hour: '2-digit', minute: '2-digit' };
  return `${start.toLocaleTimeString([], format)}–${end.toLocaleTimeString([], format)}: ${event.summary || '(untitled)'}`;
}

function renderEvent(event) {
  const row = document.createElement('div');
  row.className = 'event-row';

  const primary = document.createElement('div');
  primary.innerHTML = `<strong>${escapeHtml(formatTimeRange(event))}</strong>`;
  row.appendChild(primary);

  const meta = document.createElement('div');
  meta.className = 'event-meta';
  const parts = [];
  if (event.location) parts.push(`📍 ${escapeHtml(event.location)}`);
  meta.innerHTML = parts.join(' | ');
  if (parts.length) row.appendChild(meta);

  if (event.recurring) {
    const label = document.createElement('div');
    label.className = 'recurring-label';
    label.textContent = I18N.recurring_series_label;
    row.appendChild(label);
  }

  const controls = document.createElement('div');
  controls.className = 'button-row';
  if (event.editable) {
    const edit = document.createElement('a');
    edit.className = 'button-link';
    edit.href = `/edit?id=${encodeURIComponent(event.source_id || event.id)}`;
    edit.textContent = '✏️';
    controls.appendChild(edit);
  }
  if (event.deletable) {
    const form = document.createElement('form');
    form.method = 'post';
    form.action = '/delete';
    form.onsubmit = () => confirm(I18N.delete_confirm);
    form.innerHTML = `<input type="hidden" name="id" value="${escapeAttr(event.source_id || event.id)}"><input type="hidden" name="confirm" value="yes"><button type="submit" class="danger">❌</button>`;
    controls.appendChild(form);
  }
  if (controls.childNodes.length) row.appendChild(controls);
  return row;
}

function escapeHtml(value) {
  return String(value).replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;');
}

function escapeAttr(value) {
  return escapeHtml(value).replaceAll('"', '&quot;');
}

updateLiveClock();
window.setInterval(updateLiveClock, 1000);
loadEvents();
</script>
"""
    return script.replace("__I18N__", translations)


def form_script(lang: str) -> str:
    translations = js_translations(lang)
    script = """
<script>
const I18N = __I18N__;
const form = document.getElementById('event-form');
const allDay = document.getElementById('all_day');
const timedFields = document.querySelector('.timed-fields');
const allDayFields = document.querySelector('.all-day-fields');

function toggleMode() {
  const enabled = allDay.checked;
  timedFields.style.display = enabled ? 'none' : 'grid';
  allDayFields.style.display = enabled ? 'grid' : 'none';
  document.getElementById('start_local').required = !enabled;
  document.getElementById('end_local').required = !enabled;
  document.getElementById('start_date').required = enabled;
  document.getElementById('end_date').required = enabled;
}

function localValueToUtcIso(value) {
  if (!value) return '';
  const date = new Date(value);
  return date.toISOString().replace('.000Z', 'Z');
}

function addMinutesToLocalValue(value, minutes) {
  if (!value) return '';
  const date = new Date(value);
  date.setMinutes(date.getMinutes() + minutes);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  const hour = String(date.getHours()).padStart(2, '0');
  const minute = String(date.getMinutes()).padStart(2, '0');
  return `${year}-${month}-${day}T${hour}:${minute}`;
}

document.getElementById('start_local').addEventListener('blur', () => {
  const startLocal = document.getElementById('start_local').value;
  const endLocalInput = document.getElementById('end_local');
  if (startLocal && !endLocalInput.value) {
    endLocalInput.value = addMinutesToLocalValue(startLocal, 15);
  }
});

document.getElementById('start_date').addEventListener('blur', () => {
  const startDate = document.getElementById('start_date').value;
  const endDateInput = document.getElementById('end_date');
  if (startDate && !endDateInput.value) {
    endDateInput.value = startDate;
  }
});

function clearValidity() {
  document.getElementById('start_local').setCustomValidity('');
  document.getElementById('end_local').setCustomValidity('');
  document.getElementById('start_date').setCustomValidity('');
  document.getElementById('end_date').setCustomValidity('');
}

for (const id of ['start_local', 'end_local', 'start_date', 'end_date']) {
  document.getElementById(id).addEventListener('input', clearValidity);
  document.getElementById(id).addEventListener('change', clearValidity);
}

form.addEventListener('submit', (event) => {
  clearValidity();
  if (!allDay.checked) {
    const startLocalInput = document.getElementById('start_local');
    const endLocalInput = document.getElementById('end_local');
    const startLocal = startLocalInput.value;
    const endLocal = endLocalInput.value;
    document.getElementById('start_utc').value = localValueToUtcIso(startLocal);
    document.getElementById('end_utc').value = localValueToUtcIso(endLocal);
    if (!startLocalInput.reportValidity() || !endLocalInput.reportValidity()) {
      event.preventDefault();
      return;
    }
    if (new Date(endLocal) <= new Date(startLocal)) {
      event.preventDefault();
      endLocalInput.setCustomValidity(I18N.end_after_start);
      endLocalInput.reportValidity();
      return;
    }
    return;
  }

  const startDateInput = document.getElementById('start_date');
  const endDateInput = document.getElementById('end_date');
  if (!startDateInput.reportValidity() || !endDateInput.reportValidity()) {
    event.preventDefault();
    return;
  }
  if (startDateInput.value && endDateInput.value && endDateInput.value < startDateInput.value) {
    event.preventDefault();
    endDateInput.setCustomValidity(I18N.end_same_or_later);
    endDateInput.reportValidity();
    return;
  }
});

allDay.addEventListener('change', toggleMode);
