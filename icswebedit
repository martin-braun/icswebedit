def preferred_language(header_value: str | None) -> str:
    if not header_value:
        return "en"
    for part in header_value.split(","):
        token = part.split(";", 1)[0].strip().lower()
        if not token:
            continue
        if token in TRANSLATIONS:
            return token
        base = token.split("-", 1)[0]
        if base in TRANSLATIONS:
            return base
    return "en"


def tr(lang: str, key: str) -> str:
    return TRANSLATIONS.get(lang, TRANSLATIONS["en"]).get(key, TRANSLATIONS["en"].get(key, key))


def js_translations(lang: str) -> str:
    bundle = {
        key: tr(lang, key)
        for key in [
            "loading_events",
            "no_future_events",
            "failed_load_events",
            "recurring_series_label",
            "delete_confirm",
            "all_day",
            "start_required",
            "end_required",
            "end_after_start",
            "end_same_or_later",
        ]
    }
    return json.dumps(bundle, ensure_ascii=False)


def localize_option_label(lang: str, label: str) -> str:
    if label in TRANSLATIONS["en"]:
        return tr(lang, label)
    if " " in label:
        amount, unit = label.split(" ", 1)
        unit_key = {
            "minutes": "minutes_unit",
            "hours": "hours_unit",
            "days": "days_unit",
            "week": "week_unit",
        }.get(unit)
        if unit_key:
            return f"{amount} {tr(lang, unit_key)}"
    return label


