def form_values_from_component(component: Event) -> dict[str, str]:
    values = {
        "summary": str(component.get("SUMMARY", "")),
        "location": str(component.get("LOCATION", "")),
        "description": str(component.get("DESCRIPTION", "")),
        "rrule": recurrence_freq_value(component),
        "alarm_trigger": alarm_choice_value(component),
        "all_day": "1" if is_all_day_component(component) else "",
        "start_local": "",
        "end_local": "",
        "start_date": "",
        "end_date": "",
    }

    if is_all_day_component(component):
        start = event_start(component)
        end = event_end(component)
        assert isinstance(start, date) and not isinstance(start, datetime)
        assert isinstance(end, date) and not isinstance(end, datetime)
        values["start_date"] = start.isoformat()
        values["end_date"] = all_day_inclusive_end_date(start, end).isoformat()
    else:
        start = event_start_utc(component).astimezone()
        end = event_end_utc(component).astimezone()
        values["start_local"] = start.strftime("%Y-%m-%dT%H:%M")
        values["end_local"] = end.strftime("%Y-%m-%dT%H:%M")
    return values


